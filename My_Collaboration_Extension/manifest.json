{
  "manifest_version": 3,
  "name": "EduSync: Collaboration Hub Enforcer",
  "version": "1.2",
  "description": "Strict Focus Mode for students.",
  "permissions": ["notifications", "storage", "alarms", "tabs", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "action": { "default_popup": "popup.html" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://localhost:5173/*"],
      "js": ["content.js"]
    }
  ]
}